{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "allowJs": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": [
      "vite/client",
      "@chakra-ui/react",
      "react",
      "react-dom",
      "react-router-dom",
      "zustand"
    ]
  },
  "include": [
    "src/**/*.jsx",
    "src/**/*.js",
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build"
  ]
}
